APP_NAME="Hotspot Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# DATABASE (MySQL / MariaDB)
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=radius
DB_USERNAME=radius
DB_PASSWORD=secret

# -----------------------------------------------
# FREERADIUS
# -----------------------------------------------
RADIUS_SECRET=testing123
RADIUS_HOST=127.0.0.1
RADIUS_PORT=1812

# -----------------------------------------------
# MIKROTIK RouterOS API (opcional)
# -----------------------------------------------
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=
MIKROTIK_PORT=8728
MIKROTIK_ENABLED=false

# -----------------------------------------------
# CAPTIVE PORTAL
# -----------------------------------------------
PORTAL_ALLOWED_PLANS=true
PORTAL_DEFAULT_PLAN=basic
PORTAL_REQUIRE_PHONE=false

# -----------------------------------------------
# SESSÃO / CACHE
# -----------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hotspot@example.com"
MAIL_FROM_NAME="${APP_NAME}"
